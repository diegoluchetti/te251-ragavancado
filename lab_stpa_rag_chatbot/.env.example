# Optional lab overrides. Primary API key: repo root .env (OPEN_AI_API_KEY or OPENAI_API_KEY)
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
CHROMA_PATH=data/index/chroma
COLLECTION_NAME=stpa_handbook_children
MAX_PARENTS=3
ALLOW_OFFLINE_EMBED=0
OFFLINE_EMBED_MODEL=BAAI/bge-m3
OFFLINE_EMBED_BATCH_SIZE=8
OLLAMA_CHAT_MODEL=gemma4:latest
OLLAMA_URL=http://localhost:11434
